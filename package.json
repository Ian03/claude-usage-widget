{
  "name": "claude-usage-widget",
  "version": "0.1.1",
  "description": "Always-on-top Claude.ai plan usage widget for Windows. Lessons baked in from jens-duttke, niccolo-sabato, SlavomirDurej, thanoban, eddmann/ClaudeMeter, f-is-h/Usage4Claude.",
  "main": "src/main.js",
  "scripts": {
    "start": "node scripts/launch.js",
    "dev": "node scripts/launch.js --dev",
    "test": "node --test tests/normalize.test.js",
    "icons": "node scripts/build-icon.js",
    "demo-gif": "node scripts/build-demo-gif.js",
    "build": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "author": "Joshua Ricarder Oducado",
  "license": "MIT",
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8",
    "gifenc": "^1.0.3"
  },
  "build": {
    "appId": "com.claude-usage-widget",
    "productName": "Claude Usage Widget",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "scripts/launch.js",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "ClaudeUsageWidget-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "ClaudeUsageWidget-${version}-setup.exe"
    }
  }
}
