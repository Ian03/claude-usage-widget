{
  "name": "claude-usage-widget",
  "version": "0.1.5",
  "description": "Always-on-top Claude.ai plan usage widget for Windows. Lessons baked in from jens-duttke, niccolo-sabato, SlavomirDurej, thanoban, eddmann/ClaudeMeter, f-is-h/Usage4Claude.",
  "main": "src/main.js",
  "scripts": {
    "start": "node scripts/launch.js",
    "dev": "node scripts/launch.js --dev",
    "test": "node --test tests/normalize.test.js",
    "icons": "node scripts/build-icon.js",
    "demo-gif": "node scripts/build-demo-gif.js",
    "pill-gif": "node scripts/build-pill-gif.js",
    "og-image": "node scripts/build-og-image.js",
    "layouts-png": "node scripts/build-layouts-png.js",
    "trays-png": "node scripts/build-trays-png.js",
    "themes-png": "node scripts/build-themes-png.js",
    "thresholds-png": "node scripts/build-thresholds-png.js",
    "history-png": "node scripts/build-history-png.js",
    "settings-png": "node scripts/build-settings-png.js",
    "build": "electron-builder --win portable --publish never",
    "build:installer": "electron-builder --win nsis --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "author": "Joshua Ricarder Oducado",
  "license": "MIT",
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^25.1.8",
    "gifenc": "^1.0.3"
  },
  "overrides": {
    "tar": ">=7.5.11"
  },
  "build": {
    "appId": "com.claude-usage-widget",
    "productName": "Claude Usage Widget",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "scripts/launch.js",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "ClaudeUsageWidget-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "ClaudeUsageWidget-${version}-setup.exe"
    },
    "dmg": {
      "artifactName": "ClaudeUsageWidget-${version}-${arch}.dmg"
    },
    "appImage": {
      "artifactName": "ClaudeUsageWidget-${version}-${arch}.AppImage"
    }
  }
}
